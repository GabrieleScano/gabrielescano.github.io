---
/** The "pass" check — the recurring test-runner signature mark. */
interface Props {
  label?: string;
}
const { label } = Astro.props;
---

<span class="inline-flex items-center gap-2 font-mono text-sm text-muted">
  <svg
    class="h-4 w-4 shrink-0 text-accent"
    viewBox="0 0 16 16"
    fill="none"
    aria-hidden="true"
  >
    <path
      d="M13.5 4.5 6.5 11.5 3 8"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
  </svg>
  {label && <span>{label}</span>}
  <slot />
</span>
