---
import Check from './Check.astro';
const year = new Date().getFullYear();
const languages = ['Italian (native)', 'Spanish', 'Catalan', 'English'];
---

<footer id="contact" class="border-t border-line bg-surface">
  <div
    class="mx-auto grid max-w-5xl gap-10 px-[var(--spacing-gutter)] py-14 sm:grid-cols-2"
  >
    <div>
      <h2 class="font-display text-2xl font-semibold tracking-tight text-ink">
        Let's talk quality.
      </h2>
      <p class="mt-3 max-w-sm text-muted">
        Open to QA Automation and Functional roles in Barcelona or remote.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href="mailto:gabrielescano.bcn@gmail.com"
          class="rounded-full bg-ink px-5 py-2 text-sm font-medium text-bg transition-opacity hover:opacity-90"
        >
          Email me
        </a>
        <a
          href="https://github.com/GabrieleScano"
          rel="me noopener"
          class="rounded-full border border-line px-5 py-2 text-sm font-medium text-ink transition-colors hover:border-accent hover:text-accent"
        >
          GitHub
        </a>
      </div>
    </div>

    <div class="sm:justify-self-end">
      <h3 class="font-mono text-xs uppercase tracking-widest text-muted">
        Languages
      </h3>
      <ul class="mt-3 space-y-1 text-sm text-ink/80">
        {languages.map((lang) => <li>{lang}</li>)}
      </ul>
    </div>
  </div>

  <div class="border-t border-line">
    <div
      class="mx-auto flex max-w-5xl flex-col gap-3 px-[var(--spacing-gutter)] py-5 text-xs text-muted sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} Gabriele Scano</p>
      <Check label="Built with Astro · tested with Playwright" />
    </div>
  </div>
</footer>
