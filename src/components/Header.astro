---
// Absolute hashes so the nav works from project detail pages too.
const links = [
  { href: '/#projects', label: 'Projects' },
  { href: '/demo', label: 'Live demo' },
  { href: '/#approach', label: 'Approach' },
];
---

<header
  class="sticky top-0 z-40 border-b border-line/70 bg-bg/80 backdrop-blur supports-[backdrop-filter]:bg-bg/60"
>
  <div
    class="mx-auto flex max-w-5xl items-center justify-between px-[var(--spacing-gutter)] py-4"
  >
    <a
      href="/"
      class="font-display text-base font-semibold tracking-tight text-ink"
    >
      Gabriele Scano
    </a>
    <nav aria-label="Primary">
      <ul class="flex items-center gap-6 text-sm">
        {
          links.map((link) => (
            <li class="hidden sm:block">
              <a
                href={link.href}
                class="text-muted transition-colors hover:text-ink"
              >
                {link.label}
              </a>
            </li>
          ))
        }
        <li>
          <a
            href="https://github.com/GabrieleScano"
            class="rounded-full border border-line px-4 py-1.5 font-medium text-ink transition-colors hover:border-accent hover:text-accent"
            target="_blank"
            rel="me noopener"
          >
            GitHub
          </a>
        </li>
        <li>
          <button
            id="theme-toggle"
            type="button"
            class="flex h-9 w-9 items-center justify-center rounded-full border border-line text-muted transition-colors hover:border-accent hover:text-accent"
            aria-label="Toggle dark mode"
          >
            <svg class="icon-sun h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4"></circle>
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
            </svg>
            <svg class="icon-moon h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  /* Show the icon for the theme you'll switch TO. */
  .icon-sun {
    display: none;
  }
  html[data-theme='dark'] .icon-sun {
    display: block;
  }
  html[data-theme='dark'] .icon-moon {
    display: none;
  }
</style>

<script>
  const btn = document.getElementById('theme-toggle');
  const root = document.documentElement;
  const sync = () => btn?.setAttribute('aria-pressed', String(root.dataset.theme === 'dark'));
  sync();
  btn?.addEventListener('click', () => {
    const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
    root.dataset.theme = next;
    localStorage.setItem('theme', next);
    sync();
  });
</script>
