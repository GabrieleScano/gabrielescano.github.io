---
import '@fontsource-variable/inter';
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Gabriele Scano — QA Engineer',
  description = 'QA Engineer & Functional Analyst in Barcelona. Test automation with Playwright + TypeScript, shift-left functional analysis, and AI-augmented QA.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* Set the theme before paint to avoid a flash of the wrong theme. */}
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        const theme =
          stored ??
          (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
      })();
    </script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Structured data: Person -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: 'Gabriele Scano',
        jobTitle: 'QA Engineer',
        address: { '@type': 'PostalAddress', addressLocality: 'Barcelona' },
        url: Astro.site?.toString(),
        sameAs: ['https://github.com/GabrieleScano'],
      })}
    />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot />
  </body>
</html>
