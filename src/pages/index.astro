---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Check from '../components/Check.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order,
);

const totalTests = projects.reduce((sum, p) => sum + p.data.testCount, 0);

const skills = [
  'Playwright',
  'TypeScript',
  'Page Object Model',
  'API testing',
  'K6 load testing',
  'CI/CD',
  'Functional analysis',
  'Agile / Scrum',
];
---

<BaseLayout>
  <Header />

  <main id="main">
    <!-- Hero -->
    <section class="mx-auto max-w-5xl px-[var(--spacing-gutter)] pb-16 pt-20 sm:pt-28">
      <p class="font-mono text-sm text-muted">
        QA Engineer · Functional Analyst · Barcelona
      </p>

      <h1
        class="mt-6 max-w-3xl font-display text-5xl font-semibold leading-[1.05] tracking-tight text-ink sm:text-6xl md:text-7xl"
      >
        Quality starts<br />before the code.
      </h1>

      <p class="mt-7 max-w-xl text-lg leading-relaxed text-muted">
        I clarify requirements, prevent defects early, and build test automation
        teams can trust. Less about counting bugs — more about <em
          class="text-ink not-italic">why</em
        > they happen.
      </p>

      <div
        class="mt-9 inline-flex flex-wrap items-center gap-x-6 gap-y-3 rounded-xl border border-line bg-surface px-5 py-4"
      >
        <Check label={`${totalTests} automated tests`} />
        <Check label="3 CI pipelines green" />
        <Check label="cross-browser · API · load" />
      </div>

      <div class="mt-9 flex flex-wrap gap-3">
        <a
          href="#projects"
          class="rounded-full bg-ink px-6 py-2.5 text-sm font-medium text-bg transition-opacity hover:opacity-90"
        >
          View projects
        </a>
        <a
          href="https://github.com/GabrieleScano"
          rel="me noopener"
          class="rounded-full border border-line px-6 py-2.5 text-sm font-medium text-ink transition-colors hover:border-accent hover:text-accent"
        >
          GitHub
        </a>
      </div>
    </section>

    <!-- Projects -->
    <section
      id="projects"
      class="mx-auto max-w-5xl scroll-mt-20 px-[var(--spacing-gutter)] py-16"
    >
      <div class="flex items-end justify-between gap-4">
        <h2 class="font-display text-3xl font-semibold tracking-tight text-ink">
          Featured projects
        </h2>
        <p class="hidden max-w-xs text-right text-sm text-muted sm:block">
          Self-contained and runnable — clone, run, inspect end to end.
        </p>
      </div>

      <div class="mt-10 grid gap-6">
        {
          projects.map((project, i) => (
            <ProjectCard
              index={i + 1}
              title={project.data.title}
              tagline={project.data.tagline}
              href={`/projects/${project.id}/`}
              repo={project.data.repo}
              stack={project.data.stack}
              metrics={project.data.metrics}
              highlights={project.data.highlights}
            />
          ))
        }
      </div>
    </section>

    <!-- Approach -->
    <section
      id="approach"
      class="mx-auto max-w-5xl scroll-mt-20 px-[var(--spacing-gutter)] py-16"
    >
      <h2 class="font-display text-3xl font-semibold tracking-tight text-ink">
        How I work
      </h2>
      <div class="mt-10 grid gap-8 sm:grid-cols-3">
        <div>
          <h3 class="font-mono text-sm text-accent">shift-left</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink/80">
            The cheapest defect to fix is an ambiguous requirement. I turn user
            stories into clear, testable scenarios before any code is written.
          </p>
        </div>
        <div>
          <h3 class="font-mono text-sm text-accent">automation that lasts</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink/80">
            Maintainable design — Page Object Model, semantic locators, web-first
            assertions, isolated tests — so suites stay trustworthy as they grow.
          </p>
        </div>
        <div>
          <h3 class="font-mono text-sm text-accent">AI, with judgement</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink/80">
            I use AI to accelerate test design and requirements review — validated
            and bounded, never replacing engineering judgement.
          </p>
        </div>
      </div>

      <ul class="mt-12 flex flex-wrap gap-2">
        {
          skills.map((skill) => (
            <li class="rounded-full border border-line px-3.5 py-1.5 font-mono text-xs text-muted">
              {skill}
            </li>
          ))
        }
      </ul>
    </section>
  </main>

  <Footer />
</BaseLayout>
