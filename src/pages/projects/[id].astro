---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Check from '../../components/Check.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { title, tagline, repo, reportUrl, stack, metrics, highlights } =
  project.data;
const { Content } = await render(project);
---

<BaseLayout title={`${title} — Gabriele Scano`} description={tagline}>
  <Header />

  <main id="main" class="mx-auto max-w-3xl px-[var(--spacing-gutter)] pb-8 pt-12">
    <a
      href="/#projects"
      class="font-mono text-sm text-muted transition-colors hover:text-ink"
    >
      ← All projects
    </a>

    <h1
      class="mt-6 font-display text-4xl font-semibold tracking-tight text-ink sm:text-5xl"
    >
      {title}
    </h1>
    <p class="mt-4 max-w-prose text-lg text-muted">{tagline}</p>

    <!-- Actions -->
    <div class="mt-7 flex flex-wrap gap-3">
      {
        project.id === 'requirements-analyzer' && (
          <a
            href="/demo"
            class="rounded-full bg-accent px-5 py-2 text-sm font-medium text-white transition-opacity hover:opacity-90"
          >
            Try the live demo ↗
          </a>
        )
      }
      <a
        href={repo}
        target="_blank"
        rel="noopener"
        class="rounded-full bg-ink px-5 py-2 text-sm font-medium text-bg transition-opacity hover:opacity-90"
      >
        View repository ↗
      </a>
      <a
        href={`${repo}/actions`}
        target="_blank"
        rel="noopener"
        class="rounded-full border border-line px-5 py-2 text-sm font-medium text-ink transition-colors hover:border-accent hover:text-accent"
      >
        CI pipeline ↗
      </a>
      {
        reportUrl && (
          <a
            href={reportUrl}
            target="_blank"
            rel="noopener"
            class="rounded-full border border-accent px-5 py-2 text-sm font-medium text-accent transition-colors hover:bg-accent-soft"
          >
            Live test report ↗
          </a>
        )
      }
    </div>

    <!-- Stack -->
    <ul class="mt-8 flex flex-wrap gap-2">
      {
        stack.map((tech) => (
          <li class="rounded-full border border-line px-3 py-1 font-mono text-xs text-muted">
            {tech}
          </li>
        ))
      }
    </ul>

    <!-- Metrics -->
    <dl
      class="mt-6 grid gap-4 rounded-xl border border-line bg-surface p-5 sm:grid-cols-3"
    >
      {
        metrics.map((metric) => (
          <div>
            <dt class="sr-only">{metric.label}</dt>
            <dd>
              <Check>
                <span class="font-semibold text-ink">{metric.value}</span>
              </Check>
              <p class="mt-1 pl-6 text-xs leading-snug text-muted">
                {metric.label}
              </p>
            </dd>
          </div>
        ))
      }
    </dl>

    <!-- Highlights -->
    <ul class="mt-8 space-y-2">
      {
        highlights.map((point) => (
          <li class="flex gap-3 text-sm text-ink/80">
            <span
              class="mt-1.5 h-1 w-1 shrink-0 rounded-full bg-accent"
              aria-hidden="true"
            />
            <span>{point}</span>
          </li>
        ))
      }
    </ul>

    <!-- Markdown body -->
    <article
      class="prose prose-neutral mt-12 max-w-none prose-headings:font-display prose-headings:tracking-tight prose-a:text-accent prose-blockquote:border-l-accent prose-blockquote:bg-accent-soft/40 prose-blockquote:py-px prose-blockquote:not-italic"
    >
      <Content />
    </article>
  </main>

  <Footer />
</BaseLayout>
